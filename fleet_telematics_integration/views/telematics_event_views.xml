<?xml version="1.0" encoding="utf-8"?>
<!--
  views/telematics_event_views.xml
  หน้าจอแสดงประวัติพฤติกรรมเสี่ยงรวม (Event Logs)
  ใช้ Filter / Group By แทนการแยกหน้าจอ:
    - Harsh Brake / Speeding / Harsh Acceleration / Harsh Corner / Idling / Bump
-->
<odoo>

    <!-- ── Event List View ────────────────────────────────────────────── -->
    <record id="view_telematics_event_list" model="ir.ui.view">
        <field name="name">fleet.telematics.event.list</field>
        <field name="model">fleet.telematics.event</field>
        <field name="arch" type="xml">
            <list default_order="occurred_at desc"
                  decoration-danger="event_type=='harsh_brake'"
                  decoration-warning="event_type=='speeding' or event_type=='bump'"
                  decoration-info="event_type=='idling'">
                <field name="occurred_at"/>
                <field name="trip_id"/>
                <field name="event_type"    widget="badge"/>
                <field name="severity"/>
                <field name="speed_at_event"/>
                <field name="lat"         optional="show"/>
                <field name="lon"         optional="show"/>
                <field name="description" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ── Event Form View ────────────────────────────────────────────── -->
    <record id="view_telematics_event_form" model="ir.ui.view">
        <field name="name">fleet.telematics.event.form</field>
        <field name="model">fleet.telematics.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group string="Event Details">
                            <field name="event_type"/>
                            <field name="occurred_at"/>
                            <field name="severity"/>
                            <field name="speed_at_event"/>
                            <field name="description"/>
                        </group>
                        <group string="Trip / Vehicle / Driver">
                            <field name="trip_id"/>
                        </group>
                    </group>
                    <group string="GPS Location (พิกัด)">
                        <group>
                            <field name="lat"/>
                            <field name="lon"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Search View — Filter แทนการแยกหน้าจอ ──────────────────────── -->
    <record id="view_telematics_event_search" model="ir.ui.view">
        <field name="name">fleet.telematics.event.search</field>
        <field name="model">fleet.telematics.event</field>
        <field name="arch" type="xml">
            <search>
                <field name="trip_id"/>
                <field name="event_type"/>
                <!-- Filter แต่ละชนิดพฤติกรรม — ใช้แทนการแยกหน้าจอ -->
                <filter name="harsh_brake"  string="Harsh Brake"        domain="[('event_type','=','harsh_brake')]"/>
                <filter name="harsh_accel"  string="Harsh Acceleration" domain="[('event_type','=','harsh_accel')]"/>
                <filter name="harsh_corner" string="Harsh Corner"       domain="[('event_type','=','harsh_corner')]"/>
                <filter name="speeding"     string="Speeding"           domain="[('event_type','=','speeding')]"/>
                <filter name="idling"       string="Idling"             domain="[('event_type','=','idling')]"/>
                <filter name="bump"         string="Bump"               domain="[('event_type','=','bump')]"/>
                <separator/>
                <filter name="high_severity" string="Severity &gt; 70"
                        domain="[('severity','&gt;',70)]"/>
                <filter name="today" string="Today"
                        domain="[('occurred_at','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group>
                    <filter name="group_event_type" string="Event Type" context="{'group_by': 'event_type'}"/>
                    <filter name="group_trip"       string="Trip"       context="{'group_by': 'trip_id'}"/>
                    <filter name="group_day"        string="Day"        context="{'group_by': 'occurred_at:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Graph: Events by Type ───────────────────────────────────────── -->
    <record id="view_telematics_event_graph" model="ir.ui.view">
        <field name="name">fleet.telematics.event.graph</field>
        <field name="model">fleet.telematics.event</field>
        <field name="arch" type="xml">
            <graph string="Events by Type" type="bar" sample="1">
                <field name="event_type" type="row"/>
                <field name="severity"   type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────── -->
    <record id="action_telematics_event" model="ir.actions.act_window">
        <field name="name">Event Logs</field>
        <field name="res_model">fleet.telematics.event</field>
        <field name="view_mode">list,form,graph</field>
        <field name="search_view_id" ref="view_telematics_event_search"/>
    </record>

</odoo>
