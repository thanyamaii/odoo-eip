<?xml version="1.0" encoding="utf-8"?>
<!--
  views/telematics_payload_views.xml
  หน้าจอ API Inbox — ดูทุก request ที่ Backend ยิงเข้ามา (ดิบ + จัด format)
  แนวคิดจากโปรเจกต์ตัวอย่าง fleet_telematics
-->
<odoo>

    <!-- ── Form ───────────────────────────────────────────────── -->
    <record id="view_telematics_payload_form" model="ir.ui.view">
        <field name="name">fleet.telematics.payload.form</field>
        <field name="model">fleet.telematics.payload</field>
        <field name="arch" type="xml">
            <form string="Telematics Payload">
                <header>
                    <button name="action_mark_processed" string="✅ Mark Processed"
                            type="object" class="btn-success"
                            invisible="state == 'processed'"/>
                    <button name="action_mark_ignored" string="⚪ Ignore"
                            type="object"
                            invisible="state in ['ignored', 'processed']"/>
                    <button name="action_mark_error" string="❌ Mark Error"
                            type="object" class="btn-danger"
                            invisible="state == 'error'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,processed,error"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h2><field name="display_ref" readonly="1"/></h2>
                    </div>

                    <div class="alert alert-success mb-3" role="alert"
                         invisible="not payload_valid_json">
                        ✅ Payload เป็น JSON ที่ถูกต้อง
                    </div>
                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="payload_valid_json">
                        ⚠️ Payload ไม่ใช่ JSON / format ผิด — แจ้ง Backend ตรวจสอบ
                    </div>

                    <group>
                        <group string="📥 ข้อมูล Request">
                            <field name="received_at"/>
                            <field name="endpoint"/>
                            <field name="http_method"/>
                            <field name="remote_addr"/>
                            <field name="content_type"/>
                        </group>
                        <group string="⚙️ ผลการประมวลผล">
                            <field name="state"/>
                            <field name="trip_id"/>
                            <field name="notes"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="📄 Payload (อ่านง่าย)" name="pretty">
                            <field name="payload_pretty" nolabel="1" readonly="1"/>
                        </page>
                        <page string="🔢 Raw Payload" name="raw">
                            <field name="raw_payload" nolabel="1" readonly="1"/>
                        </page>
                        <page string="📋 HTTP Headers" name="headers">
                            <field name="http_headers" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── List ───────────────────────────────────────────────── -->
    <record id="view_telematics_payload_list" model="ir.ui.view">
        <field name="name">fleet.telematics.payload.list</field>
        <field name="model">fleet.telematics.payload</field>
        <field name="arch" type="xml">
            <list string="API Inbox"
                  decoration-success="state=='processed'"
                  decoration-danger="state=='error'"
                  decoration-muted="state=='ignored'">
                <field name="received_at"/>
                <field name="endpoint"/>
                <field name="http_method"/>
                <field name="remote_addr"/>
                <field name="payload_valid_json" string="JSON?"/>
                <field name="trip_id"/>
                <field name="state" widget="badge"
                       decoration-success="state=='processed'"
                       decoration-danger="state=='error'"
                       decoration-warning="state=='new'"/>
            </list>
        </field>
    </record>

    <!-- ── Search ─────────────────────────────────────────────── -->
    <record id="view_telematics_payload_search" model="ir.ui.view">
        <field name="name">fleet.telematics.payload.search</field>
        <field name="model">fleet.telematics.payload</field>
        <field name="arch" type="xml">
            <search>
                <field name="remote_addr"/>
                <field name="endpoint"/>
                <filter name="state_new"       string="🆕 New"       domain="[('state','=','new')]"/>
                <filter name="state_processed" string="✅ Processed" domain="[('state','=','processed')]"/>
                <filter name="state_error"     string="❌ Error"     domain="[('state','=','error')]"/>
                <separator/>
                <filter name="invalid_json"    string="⚠️ JSON ผิด format"
                        domain="[('payload_valid_json','=',False)]"/>
                <separator/>
                <filter name="group_state"     string="State" context="{'group_by':'state'}"/>
            </search>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────── -->
    <record id="action_telematics_payload" model="ir.actions.act_window">
        <field name="name">API Inbox</field>
        <field name="res_model">fleet.telematics.payload</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_state_new': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">ยังไม่มี Payload เข้ามา</p>
            <p>ทุก request ที่ Backend ยิงมาที่ Odoo จะถูกเก็บไว้ที่นี่
               ทั้งที่ประมวลผลสำเร็จและที่พัง — ใช้เป็นหลักฐานตรวจสอบกับทีม Backend</p>
        </field>
    </record>

</odoo>
