<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_telematics_vehicle_trip_history_form" model="ir.ui.view">
        <field name="name">fleet.telematics.vehicle.trip.history.form</field>
        <field name="model">fleet.telematics.vehicle.trip.history</field>
        <field name="arch" type="xml">
            <form string="ประวัติการเดินทางของรถ (Backend)">
                <sheet>
                    <!-- Filter -->
                    <group string="เลือกรถและช่วงวันที่">
                        <group>
                            <!-- ข้อ 1: เปลี่ยนจากช่องกรอก Vehicle ID (ตัวเลข) เป็น
                                 Many2one ค้นหา/เลือกได้ด้วยชื่อรุ่นรถ ทะเบียนรถ
                                 หรือชื่อคนขับ (fleet.vehicle name_search รองรับ
                                 ค้นด้วย license_plate และ driver_id อยู่แล้ว) -->
                            <field name="vehicle_id"
                                   placeholder="พิมพ์ชื่อรถ / ทะเบียน / ชื่อคนขับ เพื่อค้นหา"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="vehicle_license_plate"/>
                            <field name="driver_id"/>
                            <field name="telematics_device_id"/>
                            <field name="synced_only"/>
                        </group>
                        <group>
                            <!-- ข้อ 2: fields.Date ของ Odoo แสดง date picker (ปฏิทิน)
                                 ให้อัตโนมัติอยู่แล้วเมื่อคลิกที่ช่อง — ใช้ widget
                                 "daterange" ผูกคู่กันเพื่อให้เลือกช่วงจากปฏิทิน
                                 เดียวกันได้สะดวกขึ้น (คลิกแล้วเห็นทั้งสองเดือน
                                 พร้อมไฮไลต์ช่วงที่เลือก) -->
                            <label for="date_from" string="ช่วงวันที่ต้องการดูประวัติทริป"/>
                            <div class="o_row">
                                <field name="date_from" widget="daterange"
                                       options="{'related_end_date': 'date_to'}"
                                       string="ตั้งแต่วันที่"/>
                                <field name="date_to" widget="daterange"
                                       options="{'related_start_date': 'date_from'}"
                                       string="ถึงวันที่"/>
                            </div>
                            <field name="limit" string="แสดงต่อหน้า"/>
                        </group>
                    </group>

                    <!-- Action buttons -->
                    <div class="d-flex gap-2 mb-3">
                        <button name="action_fetch"
                                string="🔍 ดึงข้อมูล"
                                type="object" class="btn btn-primary"/>
                        <button name="action_export_excel"
                                string="📥 Export Excel"
                                type="object" class="btn btn-success"
                                invisible="not has_result"/>
                        <button name="action_prev_page"
                                string="◀ หน้าก่อน"
                                type="object" class="btn btn-secondary"
                                invisible="not has_result or page &lt;= 1"/>
                        <button name="action_next_page"
                                string="หน้าถัดไป ▶"
                                type="object" class="btn btn-secondary"
                                invisible="not has_result or page &gt;= total_pages"/>
                    </div>

                    <!-- Result -->
                    <field name="result_html" widget="html"
                           invisible="not has_result" nolabel="1"/>

                    <!-- hidden -->
                    <field name="page"        invisible="1"/>
                    <field name="total_trips" invisible="1"/>
                    <field name="total_pages" invisible="1"/>
                    <field name="has_result"  invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_telematics_vehicle_trip_history" model="ir.actions.act_window">
        <field name="name">ประวัติการเดินทางของรถ</field>
        <field name="res_model">fleet.telematics.vehicle.trip.history</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
    </record>

</odoo>