<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="fleet_telematics_integration.FleetLiveMap" owl="1">
        <div class="o_fleet_live_map d-flex flex-column"
             style="height: calc(100vh - 120px); min-height: 500px;">

            <!-- Header bar -->
            <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom bg-white">
                <div class="d-flex align-items-center gap-2">
                    <span class="fw-bold fs-5">🗺️ Fleet Live Map</span>

                    <!-- Mode badge -->
                    <span t-if="state.mode === 'connecting'"
                          class="badge text-bg-secondary">กำลังเชื่อมต่อ...</span>
                    <span t-elif="state.mode === 'sse'"
                          class="badge text-bg-success">
                        ● Live (ทุก 5 วินาที)
                    </span>
                    <span t-elif="state.mode === 'polling'"
                          class="badge text-bg-warning text-dark">
                        ⟳ Polling (ทุก 30 วินาที)
                    </span>
                    <span t-elif="state.mode === 'error'"
                          class="badge text-bg-danger">เชื่อมต่อไม่ได้</span>

                    <!-- จำนวนรถ -->
                    <span t-if="state.count > 0"
                          class="badge text-bg-primary">
                        <t t-esc="state.count"/> คัน
                    </span>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <!-- Legend -->
                    <span class="small text-muted d-flex align-items-center gap-1">
                        <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#22c55e;border:1px solid #ccc"/>
                        Ignition ON
                    </span>
                    <span class="small text-muted d-flex align-items-center gap-1">
                        <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:#ef4444;border:1px solid #ccc"/>
                        Ignition OFF
                    </span>
                    <span t-if="state.lastUpdate" class="small text-muted">
                        อัปเดต: <t t-esc="state.lastUpdate"/>
                    </span>
                </div>
            </div>

            <!-- Error bar -->
            <div t-if="state.error"
                 class="alert alert-warning mb-0 rounded-0 py-2 px-3 small">
                ⚠️ <t t-esc="state.error"/>
            </div>

            <!-- Map container -->
            <div t-ref="mapContainer" style="flex:1; z-index:0;"/>

        </div>
    </t>

</templates>
