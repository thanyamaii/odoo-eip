<?xml version="1.0" encoding="utf-8"?>
<!--
  security/telematics_groups.xml
  เพิ่มกลุ่มสิทธิ์ "Executive (Read-only)" สำหรับผู้บริหารที่ต้องการดูข้อมูล
  สรุปได้ แต่ไม่ต้องมีสิทธิ์อนุมัติ

  เดิมโมดูลนี้มีแค่ 2 กลุ่ม (fleet.fleet_group_user / fleet.fleet_group_manager)
  ทำให้ไม่มีทางแยกสิทธิ์ "ผู้บริหารดูได้อย่างเดียว ไม่ใช้อนุมัติ" — กลุ่มนี้
  ต้องถูกโหลด "ก่อน" ir.model.access.csv เสมอ (ดูลำดับ 'data' ใน
  __manifest__.py)

  หมายเหตุ: กลุ่ม Executive นี้มีไว้ "เพิ่มเติม" สำหรับให้ผู้บริหารเข้าดู
  ข้อมูลสรุปได้แบบ read-only เท่านั้น ไม่ได้แทนที่ fleet_group_manager ที่
  เป็นคนอนุมัติจริง
-->
<odoo>

    <!--
      Odoo 19 restructure res.groups ใหม่: category_id (M2O ตรงไป
      ir.module.category) ถูกถอดออก แทนที่ด้วย privilege_id (M2O ไป
      res.groups.privilege ตัวใหม่ ซึ่งค่อยไปอ้าง category_id อีกที)

      ตัดสินใจ: ถอด category/privilege ออกทั้งหมด เพราะเป็นแค่ field จัด
      หมวดหมู่ให้สวยงามใน Settings > Users > Groups เท่านั้น ไม่กระทบการ
      ทำงานของสิทธิ์ (permission) แต่อย่างใด — ลด surface area ที่จะพังจาก
      ความต่างระหว่างเวอร์ชัน Odoo ในอนาคตอีก ไม่ต้องพึ่ง ir.module.category
      หรือ res.groups.privilege เลย
    -->
    <record id="group_fleet_telematics_executive" model="res.groups">
        <field name="name">Fleet Telematics: Executive (Read-only)</field>
        <field name="comment">
            ผู้บริหาร (Executive) — เข้าดู Dashboard / Live Map / รายงานน้ำมัน /
            Driver Scorecard / สรุปยอดโบนัสรวมได้แบบ read-only เท่านั้น
            ไม่มีสิทธิ์ Confirm/Approve/Mark as Paid/แก้ไขค่าตั้งต้นใดๆ
            (ดู ir.model.access.csv และ ir.rule ที่เกี่ยวข้อง)
        </field>
    </record>

</odoo>
